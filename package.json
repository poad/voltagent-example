{
  "name": "voltagent-example",
  "version": "0.1.0",
  "description": "A VoltAgent application",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env ./src",
    "build": "tsdown",
    "start": "node dist/index.js",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "volt": "volt"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.111",
    "@dotenvx/dotenvx": "^1.69.1",
    "@voltagent/cli": "^0.1.21",
    "@voltagent/core": "^2.7.5",
    "@voltagent/libsql": "^2.1.2",
    "@voltagent/logger": "^2.0.2",
    "@voltagent/server-hono": "^2.0.13",
    "ai": "^6.0.193",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@11.2.0"
}