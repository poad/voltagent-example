{
  "name": "voltagent-example",
  "version": "0.1.0",
  "description": "A VoltAgent application",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env ./src",
    "build": "tsdown",
    "start": "node dist/index.js",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "volt": "volt"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.22",
    "@dotenvx/dotenvx": "^2.9.0",
    "@voltagent/cli": "^0.1.21",
    "@voltagent/core": "^2.9.0",
    "@voltagent/libsql": "^2.1.2",
    "@voltagent/logger": "^2.0.2",
    "@voltagent/server-hono": "^2.0.14",
    "ai": "^7.0.28",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.7",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "pnpm@11.9.0"
}